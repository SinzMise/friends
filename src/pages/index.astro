---
import Layout from '../layouts/Layout.astro';
import { getLinksData, type LinkCategory, type LinkItem } from '../utils/links';

const data = getLinksData();
---

<Layout title="友链 - FriendLink">
  <main class="max-w-7xl mx-auto px-4 py-12">
    <header class="text-center mb-16">
      <h1 class="text-4xl font-bold bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent mb-4">
        友链
      </h1>
      <p class="text-slate-600 text-lg">记录那些有趣的灵魂</p>
    </header>

    <div class="space-y-12">
      {data.links.map((category: LinkCategory) => (
        <section class="group">
          <div class="flex items-center gap-4 mb-6">
            <h2 class="text-2xl font-bold text-slate-800">{category.class_name}</h2>
            <span class="text-slate-400">—</span>
            <span class="text-slate-500">{category.class_desc}</span>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
            {category.link_list.map((link: LinkItem) => (
              <a
                href={link.link}
                target="_blank"
                rel="noopener noreferrer"
                class="group/card relative bg-white rounded-xl p-4 shadow-sm hover:shadow-lg transition-all duration-300 hover:-translate-y-1 border border-slate-100 overflow-hidden"
              >
                {category.type === 'card' && link.siteshot && (
                  <div class="absolute inset-0 opacity-0 group-hover/card:opacity-100 transition-opacity duration-300">
                    <img
                      src={link.siteshot}
                      alt=""
                      class="w-full h-full object-cover blur-[2px] scale-110"
                      loading="lazy"
                    />
                    <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
                  </div>
                )}

                <div class="relative z-10 flex items-center gap-3">
                  <img
                    src={link.avatar}
                    alt={link.name}
                    class="w-12 h-12 rounded-full object-cover ring-2 ring-slate-100 group-hover/card:ring-blue-300 transition-all"
                    loading="lazy"
                    onerror="this.src='https://cravatar.cn/avatar/default?d=mp'"
                  />
                  <div class="flex-1 min-w-0">
                    <h3 class="font-semibold text-slate-800 truncate group-hover/card:text-blue-600 transition-colors">
                      {link.name}
                    </h3>
                    <p class="text-sm text-slate-500 truncate">{link.descr}</p>
                  </div>
                </div>
              </a>
            ))}
          </div>
        </section>
      ))}
    </div>

    <footer class="mt-16 text-center text-slate-400 text-sm">
      <p>共 {data.links.reduce((acc, cat) => acc + cat.link_list.length, 0)} 个友链</p>
    </footer>
  </main>
</Layout>
